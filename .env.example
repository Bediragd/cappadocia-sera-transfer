# Docker Compose (yerel Postgres)
DATABASE_URL=postgresql://cappadocia:GUCLU_SIFRE@db:5432/cappadocia
POSTGRES_PASSWORD=GUCLU_SIFRE

# Neon kullanıyorsanız db servisini docker-compose'dan kaldırın ve:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

NODE_ENV=production
# İsteğe bağlı — harita özelliği için
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web Push bildirimleri (admin panel — cihaza)
# Uretmek icin: node scripts/generate-vapid-keys.js
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:info@cappadociaseratransfer.com

# Site adresi (mail icindeki admin panel linkleri icin)
# SITE_URL=https://cappadociaseratransfer.com

# SMTP — sadece sunucu bilgisi (.env). Gonderen/alici: Admin > Ayarlar > E-posta
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_PASS=uygulama_sifresi
